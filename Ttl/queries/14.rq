#title: Wikidata - Djeca Stefana Nemanje
#comment: Endpoint: https://query.wikidata.org/
PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?dijete ?ime ?rodjenje
WHERE {
    ?dijete wdt:P22 wd:Q183180 ;
            rdfs:label ?ime .
    OPTIONAL { ?dijete wdt:P569 ?rodjenje }
    FILTER (lang(?ime) = "en")
}
ORDER BY ?rodjenje
