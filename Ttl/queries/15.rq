#title: DBpedia - Pravoslavni manastiri u Srbiji
#comment: Endpoint: https://dbpedia.org/sparql
PREFIX dbo: <http://dbpedia.org/ontology/>
PREFIX dbr: <http://dbpedia.org/resource/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT DISTINCT ?manastir ?ime
WHERE {
    ?manastir a dbo:ReligiousBuilding ;
              rdfs:label ?ime ;
              dbo:location dbr:Serbia .
    FILTER (lang(?ime) = "en")
}
ORDER BY ?ime
LIMIT 20
