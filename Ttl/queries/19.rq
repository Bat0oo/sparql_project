#title: Wikidata - Detalji o Svetom Savi
#comment: Endpoint: https://query.wikidata.org/
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>

SELECT ?property ?value
WHERE {
    ?sveti rdfs:label "Saint Sava"@en .
    VALUES ?property { wdt:P569 wdt:P570 wdt:P27 wdt:P106 wdt:P22 wdt:P19 }
    ?sveti ?property ?value .
}
LIMIT 15
